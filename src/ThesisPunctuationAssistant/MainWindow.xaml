<Window x:Class="ThesisPunctuationAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Word 论文标点交互式检查助手 (MVP)" Height="700" Width="1180">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="连接当前 Word" Command="{Binding ConnectWordCommand}" Margin="0,0,8,0" Padding="14,6"/>
            <Button Content="打开文档" Command="{Binding OpenDocumentCommand}" Margin="0,0,8,0" Padding="14,6"/>
            <Button Content="开始检测" Command="{Binding StartScanCommand}" Margin="0,0,8,0" Padding="14,6"/>
            <Button Content="继续下一个" Command="{Binding NextIssueCommand}" Margin="0,0,8,0" Padding="14,6"/>
            <Button Content="自动替换" Command="{Binding AutoReplaceCommand}" Margin="0,0,8,0" Padding="14,6"/>
            <Button Content="导出报告" Command="{Binding ExportReportCommand}" Padding="14,6"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="检测状态" Grid.Column="0" Margin="0,0,10,0">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DocumentInfo}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ZoneModeInfo}" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="当前问题详情" Grid.Column="1">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding CurrentIssueSummary}" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Text="{Binding CurrentIssueReason}" Margin="0,6,0,6"/>
                    <TextBox Grid.Row="2" Text="{Binding CurrentIssueContext}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Header="问题列表" Grid.Row="2" Margin="0,10,0,10">
            <DataGrid ItemsSource="{Binding Issues}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                    <DataGridTextColumn Header="区域" Binding="{Binding Zone}" Width="100"/>
                    <DataGridTextColumn Header="符号" Binding="{Binding Symbol}" Width="60"/>
                    <DataGridTextColumn Header="建议" Binding="{Binding Suggestion}" Width="120"/>
                    <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding ProgressText}"/>
        </StatusBar>
    </Grid>
</Window>
