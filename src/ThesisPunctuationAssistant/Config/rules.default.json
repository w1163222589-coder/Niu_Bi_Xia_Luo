{
  "SuspiciousEnglishPunctuation": [",", ".", ":", ";", "(", ")", "\"", "?", "!", "-"],
  "AllowedRegexes": [
    "https?://\\S+",
    "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+",
    "\\bdoi:\\s*10\\.[^\\s]+",
    "\\b(Fig|Eq|IEEE|Trans)\\.",
    "\\([a-zA-Z]\\)",
    "式\\(\\d+-\\d+\\)",
    "\\d+\\.\\d+",
    "^\\s*\\d+\\.\\s",
    "\\[\\d+(,\\s*\\d+)*(-\\d+)?\\]"
  ],
  "SuggestionMap": {
    ",": "，",
    ".": "。",
    ":": "：",
    ";": "；",
    "(": "（",
    ")": "）",
    "\"": "“/”",
    "?": "？",
    "!": "！",
    "-": "——"
  }
}
